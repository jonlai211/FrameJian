{
  "manifest_version": 3,
  "name": "Video Notes (Minimal)",
  "version": "0.1.0",
  "description": "Take timestamped notes while watching YouTube or Bilibili.",
  "options_page": "options.html",
  "background": {
    "service_worker": "src/background.js"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtu.be/*",
        "https://www.bilibili.com/*"
      ],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ]
}
